OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=

# LLM defaults
DEFAULT_AI_PROVIDER=xAI (Grok)
