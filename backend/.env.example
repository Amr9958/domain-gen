DOMAIN_INTEL_APP_NAME="Domain Intelligence API"
DOMAIN_INTEL_ENV=local
DOMAIN_INTEL_DEBUG=false
DOMAIN_INTEL_API_V1_PREFIX=/v1

DATABASE_URL=postgresql+psycopg://domain_intel:domain_intel@localhost:5432/domain_intel
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
